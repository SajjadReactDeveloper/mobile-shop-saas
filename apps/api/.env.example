# ─── Database (Neon PostgreSQL) ───────────────────────────────────────────────
# Use the POOLED connection string in production (prevents connection exhaustion)
# In Neon dashboard: Connection Details → Connection pooling → toggle ON → copy URL
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.neon.tech/mobile_shop?sslmode=require"

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="change-me-to-64-random-hex-chars-in-production"
JWT_EXPIRES_IN="7d"

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
# In production set this to your Render URL:
GOOGLE_CALLBACK_URL="https://mobile-shop-saas.onrender.com/api/v1/auth/google/callback"

# ─── Cloudinary ───────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ─── WhatsApp Business API (Meta) ─────────────────────────────────────────────
# Use a SYSTEM USER permanent token (never expires) — not a temporary user token
# Meta Business Suite → Business Settings → System Users → generate token
WHATSAPP_TOKEN="your-permanent-system-user-token"
WHATSAPP_PHONE_NUMBER_ID="your-phone-number-id"

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Use sk_live_ for production, sk_test_ for development
STRIPE_SECRET_KEY="sk_test_..."
# Get from Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─── App / CORS ───────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production
# Comma-separated list of allowed origins (no trailing slash)
ALLOWED_ORIGINS="https://mobile-shop-saas-web.vercel.app,https://yourdomain.com"
WEB_URL="https://mobile-shop-saas-web.vercel.app"
